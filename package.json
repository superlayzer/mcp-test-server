{
  "name": "mcp-test-server",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/node.ts",
    "build": "tsc",
    "start": "node dist/node.js",
    "typecheck": "tsc --noEmit",
    "deploy": "wrangler deploy"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.29.0",
    "@hono/node-server": "^1.19.13",
    "fetch-to-node": "^2.1.0",
    "hono": "^4.12.12",
    "zod": "^4.3.5"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.0.0",
    "@types/node": "^20.0.0",
    "tsx": "^4.19.1",
    "typescript": "^5.8.2",
    "wrangler": "^4.0.0"
  },
  "version": "1.0.0",
  "description": "Reference MCP server demonstrating the MCP Apps spec — widgets, state persistence, destructive-action confirmation, handshake timeouts",
  "author": "Superlayzer",
  "license": "MIT",
  "repository": {
    "type": "git",
