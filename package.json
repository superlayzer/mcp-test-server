{
  "name": "mcp-test-server",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/node.ts",
    "build": "tsc",
    "start": "node dist/node.js",
    "typecheck": "tsc --noEmit",
    "deploy": "wrangler deploy"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.29.0",
    "@hono/node-server": "1.19.14",
    "fetch-to-node": "2.1.0",
    "hono": "4.12.14",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "4.20260131.0",
    "@types/node": "20.19.30",
    "tsx": "4.21.0",
    "typescript": "5.9.3",
    "wrangler": "4.80.0"
  },
  "version": "1.0.0",
  "description": "Reference MCP server demonstrating the MCP Apps spec — widgets, state persistence, destructive-action confirmation, handshake timeouts",
  "author": "Superlayzer",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/superlayzer/mcp-test-server.git"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "ext-apps",
    "widgets",
    "cloudflare-workers"
  ],
  "packageManager": "pnpm@10.19.0",
  "engines": {
    "node": ">=20.0.0"
  }
}
